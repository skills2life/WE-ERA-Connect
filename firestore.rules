rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validations
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'category', 'subject', 'message', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.category is string && data.category.size() > 0 && data.category.size() <= 128
        && data.subject is string && data.subject.size() <= 128
        && data.message is string && data.message.size() > 0 && data.message.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'email', 'category', 'passType', 'paymentStatus', 'paymentMethod', 'amount', 'transactionId', 'cardholderName', 'createdAt'])
        && data.keys().size() == 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.category is string && data.category.size() <= 128
        && data.passType is string && (data.passType == 'delegate' || data.passType == 'vip' || data.passType == 'academic')
        && data.paymentStatus is string && (data.paymentStatus == 'paid' || data.paymentStatus == 'pending' || data.paymentStatus == 'failed')
        && data.paymentMethod is string && (data.paymentMethod == 'card' || data.paymentMethod == 'apple_pay' || data.paymentMethod == 'google_pay')
        && data.amount is number && data.amount >= 0
        && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 128
        && data.cardholderName is string && data.cardholderName.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidFellowship(data) {
      return data.keys().hasAll(['nameEn', 'nameAr', 'email', 'phone', 'school', 'abstract', 'degree', 'boardType', 'yearsExp', 'totalMonthly', 'refId', 'createdAt'])
        && data.keys().size() == 12
        && data.nameEn is string && data.nameEn.size() > 0 && data.nameEn.size() <= 128
        && data.nameAr is string && data.nameAr.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.phone is string && data.phone.size() <= 32
        && data.school is string && data.school.size() <= 128
        && data.abstract is string && data.abstract.size() > 0 && data.abstract.size() <= 2000
        && data.degree is string && data.degree.size() <= 64
        && data.boardType is string && data.boardType.size() <= 64
        && data.yearsExp is number
        && data.totalMonthly is number
        && data.refId is string && data.refId.size() > 0 && data.refId.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidPitch(data) {
      return data.keys().hasAll(['leadName', 'teamName', 'email', 'pitchTitle', 'elevatorPitch', 'pledgeCapital', 'techTrack', 'deploymentScale', 'estimationPartner', 'requiredMilestones', 'mentors', 'refId', 'createdAt'])
        && data.keys().size() == 13
        && data.leadName is string && data.leadName.size() > 0 && data.leadName.size() <= 128
        && data.teamName is string && data.teamName.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.pitchTitle is string && data.pitchTitle.size() > 0 && data.pitchTitle.size() <= 128
        && data.elevatorPitch is string && data.elevatorPitch.size() > 0 && data.elevatorPitch.size() <= 2000
        && data.pledgeCapital is number && data.pledgeCapital >= 0
        && data.techTrack is string && data.techTrack.size() <= 64
        && data.deploymentScale is string && data.deploymentScale.size() <= 64
        && data.estimationPartner is string && data.estimationPartner.size() <= 256
        && data.requiredMilestones is string && data.requiredMilestones.size() <= 512
        && data.mentors is string && data.mentors.size() <= 256
        && data.refId is string && data.refId.size() > 0 && data.refId.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidEducator(data) {
      return data.keys().hasAll(['name', 'email', 'schoolName', 'educatorRole', 'subjectTaught', 'yearsExperience', 'emirate', 'registrationCode', 'createdAt'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() > 0 && data.name.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 128
        && data.schoolName is string && data.schoolName.size() > 0 && data.schoolName.size() <= 128
        && data.educatorRole is string && data.educatorRole.size() > 0 && data.educatorRole.size() <= 128
        && data.subjectTaught is string && data.subjectTaught.size() <= 128
        && data.yearsExperience is number && data.yearsExperience >= 0 && data.yearsExperience <= 60
        && data.emirate is string && data.emirate.size() > 0 && data.emirate.size() <= 64
        && data.registrationCode is string && data.registrationCode.size() > 0 && data.registrationCode.size() <= 128
        && data.createdAt == request.time;
    }

    // Rules for each collection
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow read, update, delete: if false;
    }

    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId) && isValidRegistration(incoming());
      allow read, update, delete: if false;
    }

    match /fellowships/{fellowshipId} {
      allow create: if isValidId(fellowshipId) && isValidFellowship(incoming());
      allow read, update, delete: if false;
    }

    match /pitches/{pitchId} {
      allow create: if isValidId(pitchId) && isValidPitch(incoming());
      allow read, update, delete: if false;
    }

    match /educators/{educatorId} {
      allow create: if isValidId(educatorId) && isValidEducator(incoming());
      allow read, update, delete: if false;
    }
  }
}
