{
  "entities": {
    "inquiry": {
      "title": "Inquiry",
      "description": "General or specialized inquiry form submissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "category", "message", "createdAt"]
    },
    "registration": {
      "title": "Registration",
      "description": "Attendee summit ticket bookings and billing captures",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "category": { "type": "string" },
        "passType": { "type": "string", "enum": ["delegate", "vip", "academic"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "pending", "failed"] },
        "paymentMethod": { "type": "string", "enum": ["card", "apple_pay", "google_pay"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "cardholderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "passType", "paymentStatus", "paymentMethod", "amount", "transactionId", "createdAt"]
    },
    "fellowship": {
      "title": "FellowshipApplication",
      "description": "Emiratization PhD fellowship applications and research abstracts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nameAr": { "type": "string" },
        "nameEn": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "school": { "type": "string" },
        "abstract": { "type": "string" },
        "degree": { "type": "string" },
        "boardType": { "type": "string" },
        "yearsExp": { "type": "number" },
        "totalMonthly": { "type": "number" },
        "refId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameEn", "email", "abstract", "refId", "createdAt"]
    },
    "pitch": {
      "title": "VenturePitch",
      "description": "WE-Shark Tank venture pitch submissions and EdTech ideas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "leadName": { "type": "string" },
        "teamName": { "type": "string" },
        "email": { "type": "string" },
        "pitchTitle": { "type": "string" },
        "elevatorPitch": { "type": "string" },
        "pledgeCapital": { "type": "number" },
        "techTrack": { "type": "string" },
        "deploymentScale": { "type": "string" },
        "estimationPartner": { "type": "string" },
        "requiredMilestones": { "type": "string" },
        "mentors": { "type": "string" },
        "refId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leadName", "email", "pitchTitle", "elevatorPitch", "refId", "createdAt"]
    },
    "educator": {
      "title": "EducatorRegistration",
      "description": "Accredited educator registration and teaching profile details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "schoolName": { "type": "string" },
        "educatorRole": { "type": "string" },
        "subjectTaught": { "type": "string" },
        "yearsExperience": { "type": "number" },
        "emirate": { "type": "string" },
        "registrationCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "schoolName", "educatorRole", "emirate", "registrationCode", "createdAt"]
    }
  },
  "firestore": {
    "inquiries": {
      "schema": "inquiry",
      "description": "Stores contact or direct inquiry inputs from users"
    },
    "registrations": {
      "schema": "registration",
      "description": "Stores user summit bookings and payment transitions"
    },
    "fellowships": {
      "schema": "fellowship",
      "description": "Stores Emiratization fellowship applications"
    },
    "pitches": {
      "schema": "pitch",
      "description": "Stores WE-Shark Tank pitch entries"
    },
    "educators": {
      "schema": "educator",
      "description": "Stores accredited educator registration entries"
    }
  }
}
